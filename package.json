{
  "name": "elproof",
  "private": true,
  "version": "0.1.0",
  "description": "ElProof — monorepo (Dimas standard)",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "cd apps/api && air",
    "build:web": "npm run build -w apps/web",
    "build:api": "cd apps/api && go build -o ../../dist/api ./cmd/server",
    "migrate:up": "cd apps/api && migrate -path migrations -database \"$DATABASE_URL\" up",
    "migrate:down": "cd apps/api && migrate -path migrations -database \"$DATABASE_URL\" down 1",
    "migrate:create": "cd apps/api && migrate create -ext sql -dir migrations -seq",
    "sqlc:generate": "cd apps/api && sqlc generate"
  }
}
