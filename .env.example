APP_ENV=development
APP_PORT=8080
APP_NAME=ElProof

# DB_HOST/DB_PORT/DB_USER/DB_PASSWORD/DB_NAME feed two different things:
# - DATABASE_URL below (used when running the API directly on the host, e.g.
#   `npm run dev:api` or `npm run migrate:up`) — keep DB_HOST=localhost here.
# - docker-compose.yml's own DATABASE_URL override, which reuses these same
#   DB_USER/DB_PASSWORD/DB_PORT/DB_NAME values but swaps the host for
#   `host.docker.internal` so the app container can reach a host-run MySQL.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=elproof_db
DATABASE_URL=mysql://root:@tcp(localhost:3306)/elproof_db

JWT_SECRET=change-me
JWT_ACCESS_TTL=30m
JWT_REFRESH_TTL=168h
# How long an external payment App's token (Fase 10, POST /auth/app/token)
# stays valid. No refresh token exists for this principal type — the App
# just re-exchanges appId+secret once this expires.
APP_TOKEN_TTL=1h

VITE_API_BASE_URL=http://localhost:8080

# Object storage (S3-compatible — IDCloudHost Object Storage or any S3-compatible
# provider). See ADR-0006. Never commit real keys — this file only ever holds
# placeholders.
S3_ENDPOINT=change-me.example.com
S3_BUCKET=change-me
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me
S3_USE_SSL=true

# `payment` module (knowledge/MODULE_PAYMENT.md) — the ONE secret this module
# ever accepts living outside the database. Derives the AES-256-GCM key used
# to encrypt the gateway credential (Tripay merchant code/API key/private
# key) and external Apps' reversible secret copy (Fase 10, used only to sign
# outbound webhook relays) — see MODULE_PAYMENT.md §8. The actual Tripay
# credentials are configured through the Platform Console's "Konfigurasi
# Gateway" page, not an env var — this key just has to be long, random, and
# never rotated without a plan to re-encrypt every stored credential.
PAYMENT_ENCRYPTION_KEY=change-me-to-a-long-random-string
