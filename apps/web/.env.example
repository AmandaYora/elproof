# Only used for local dev (`npm run dev:web`), where the frontend (Vite,
# port 5173) and backend (Go, port 8080) run as separate servers and every
# API call needs an absolute URL. The Docker build (infra/docker/Dockerfile)
# never sees this file — frontend and API are served from the same origin
# there, so requests are made with relative paths instead (see
# shared/services/http-client.ts).
VITE_API_BASE_URL=http://localhost:8080
